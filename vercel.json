{
  "version": 2,
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/skfdms_output/skfdms/backend/server.js" 
    },
    { 
      "source": "/", 
      "destination": "/skfdms_output/skfdms/frontend/index.html" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/skfdms_output/skfdms/frontend/$1" 
    }
  ]
}